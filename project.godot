config_version=5

[application]
config/name="GridHack"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3")
config/description="Cyberpunk arena action prototype about intrusion AIs fighting through infection nodes and network propagation."

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]
renderer/rendering_method="gl_compatibility"
environment/defaults/default_clear_color=Color(0.0156863, 0.0176471, 0.027451, 1)
